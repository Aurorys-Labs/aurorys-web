# --- PUBLIC VARIABLES (Prefix with PUBLIC_ for Astro if needed) ---
# Cloudflare Turnstile Site Key (Used on the frontend)
NEXT_PUBLIC_TURNSTILE_SITE_KEY="1x00000000000000000000AA"
PUBLIC_TURNSTILE_SITE_KEY="1x00000000000000000000AA"

# --- SECRET VARIABLES (Do not commit to version control) ---
# Resend API Key for sending emails
RESEND_API_KEY="re_xxxxxxx"

# Cloudflare Turnstile Secret Key (Used on the backend API route)
TURNSTILE_SECRET_KEY="1x0000000000000000000000000000000AA"

# -------------------------------------------------------------
# Deployment Guide:
# -------------------------------------------------------------
# 1. LOCAL DEV:
#    Rename this file to `.env` and fill in your actual API keys.
#
# 2. COOLIFY:
#    Go to your Coolify dashboard -> Projects -> [Your Project] -> Environment Variables.
#    Add the variables there (RESEND_API_KEY, TURNSTILE_SECRET_KEY, NEXT_PUBLIC_TURNSTILE_SITE_KEY).
#
# 3. GITHUB ACTIONS:
#    Go to Github Repo -> Settings -> Secrets and variables -> Actioans.
#    Add the following secrets to trigger Coolify & Cloudflare:
#      - COOLIFY_WEBHOOK_URL
#      - COOLIFY_API_TOKEN
#      - CLOUDFLARE_ZONE_ID
#      - CLOUDFLARE_API_TOKEN

---
import { ShieldCheck } from "lucide-react";

interface Props {
	hideHeader?: boolean;
}

const { hideHeader = false } = Astro.props;
---

<section
	id="contact"
	class="py-20 bg-transparent text-black dark:text-white relative overflow-hidden"
>
	{/* Background Elements */}
	<div
		class="absolute top-0 left-0 w-full h-full overflow-hidden pointer-events-none opacity-50"
	>
		<div
			class="absolute top-1/3 left-1/3 w-96 h-96 bg-[radial-gradient(circle,rgba(var(--color-1-rgb),0.15)_0%,transparent_70%)]"
		>
		</div>
		<div
			class="absolute top-[70%] left-[25%] w-[30rem] h-[30rem] bg-[radial-gradient(circle,rgba(var(--color-5-rgb),0.1)_0%,transparent_70%)]"
		>
		</div>
		<div
			class="absolute -bottom-[2%] right-1/4 w-[40rem] h-[40rem] bg-[radial-gradient(circle,rgba(var(--color-4-rgb),0.1)_0%,transparent_70%)]"
		>
		</div>
	</div>

	<div class="max-w-4xl mx-auto px-4 relative z-10">
		{!hideHeader && (
			<div class="text-center mb-12 animate-fade-in">
				<h2 class="text-4xl md:text-5xl font-bold mb-4 font-sans text-gradient-aurora">
					Get in Touch
				</h2>
				<p
					class="text-neutral-200 italic text-shadow-sm/30"
				>
					Ready to launch your project? Send us a signal.
				</p>
			</div>
		)}

		{/* MacOS Window Card */}
		<div
			class="rounded-xl border border-neutral-200 dark:border-white/10 bg-white/50 dark:bg-black/50 backdrop-blur-xl shadow-2xl dark:shadow-xl dark:shadow-neutral-900/30 overflow-hidden relative"
		>
			{/* Window Header */}
			<div
				class="h-10 bg-neutral-100/50 dark:bg-black/60 border-b border-neutral-200 dark:border-white/5 flex items-center justify-between px-4 gap-2"
			>
				<div class="flex items-center gap-2">
					<div class="w-3 h-3 rounded-full bg-red-500/80"></div>
					<div class="w-3 h-3 rounded-full bg-yellow-500/80"></div>
					<div class="w-3 h-3 rounded-full bg-green-500/80"></div>
				</div>
				<div
					class="text-xs text-neutral-700 dark:text-neutral-500 font-mono opacity-70 hidden sm:block"
				>
					secure_uplink@aurorys-labs:~/connect
				</div>
				<div
					class="text-[10px] text-emerald-700/80 dark:text-emerald-500/80 font-mono tracking-tight"
				>
					Connection: Encrypted (TLS 1.3)
				</div>
			</div>

			{/* Window Content */}
			<div class="relative p-8 min-h-[400px]">
				{/* Success Overlay (Hidden by default) */}
				<div
					id="success-overlay"
					class="hidden absolute inset-0 z-20 bg-emerald-950/40 dark:bg-emerald-950/70 backdrop-blur-lg flex-col items-center justify-center text-center p-8 animate-in fade-in duration-500 rounded-b-xl border-t border-white/5"
				>
					<div
						class="w-16 h-16 bg-emerald-500/20 text-emerald-400 rounded-full flex items-center justify-center mb-6 shadow-[0_0_30px_rgba(16,185,129,0.3)] animate-bounce"
					>
						<ShieldCheck className="w-8 h-8" />
					</div>
					<h3
						class="text-2xl font-bold text-white mb-2 shadow-black drop-shadow-md"
					>
						Transmission Successful
					</h3>
					<p
						class="text-emerald-100/90 font-mono text-sm max-w-sm leading-relaxed mb-8 drop-shadow-md"
					>
						Secure channel established. Acknowledgment receipt dispatched to
						your coordinates. We will respond within 48 hours.
					</p>
					<button
						id="reset-button"
						class="relative inline-flex items-center justify-center h-10 px-6 rounded-full font-semibold text-sm transition-all duration-300 bg-white/[0.03] text-[var(--text-stellar)] border border-white/10 hover:border-white/20 hover:bg-white/[0.05]"
					>
						Reset Terminal
					</button>
				</div>

				<form id="contact-form" class="space-y-6">
					<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
						<div class="space-y-2">
							<label
								for="name"
								class="text-sm font-medium text-neutral-700 dark:text-neutral-300 font-mono"
							>
								Identity (Name) <span class="text-red-500">*</span>
							</label>
							<input
								id="name"
								name="name"
								class="w-full my-2 px-4 py-2 rounded-md bg-neutral-100/20 dark:bg-black/30 border border-neutral-200 dark:border-white/10 text-black dark:text-white focus:outline-none focus:ring-2 focus:ring-emerald-500/50 transition-all font-mono text-sm"
								placeholder="John Doe (CEO)"
							/>
							<p id="name-error" class="text-xs text-red-400 font-mono hidden mt-1"></p>
						</div>
						<div class="space-y-2">
							<label
								for="email"
								class="text-sm font-medium text-neutral-700 dark:text-neutral-300 font-mono"
							>
								Coordinates (Email) <span class="text-red-500">*</span>
							</label>
							<input
								id="email"
								name="email"
								type="email"
								class="w-full my-2 px-4 py-2 rounded-md bg-neutral-100/20 dark:bg-black/30 border border-neutral-200 dark:border-white/10 text-black dark:text-white focus:outline-none focus:ring-2 focus:ring-emerald-500/50 transition-all font-mono text-sm"
								placeholder="john.doe@company.com"
							/>
							<p id="email-error" class="text-xs text-red-400 font-mono hidden mt-1"></p>
						</div>
					</div>

					<div class="space-y-2">
						<label
							for="subject"
							class="text-sm font-medium text-neutral-700 dark:text-neutral-300 font-mono"
						>
							Protocol
						</label>
						<div class="relative">
							<select
								id="subject"
								name="subject"
								class="w-full my-2 px-4 py-2 rounded-md bg-neutral-100/20 dark:bg-black/30 border border-neutral-200 dark:border-white/10 text-black dark:text-white focus:outline-none focus:ring-2 focus:ring-emerald-500/50 transition-all font-mono text-sm appearance-none"
							>
								<option value="PING_HELLO">PING_HELLO</option>
								<option value="FIRST_LIGHT">FIRST_LIGHT</option>
								<option value="FOUNDATION">FOUNDATION</option>
								<option value="PULSE">PULSE</option>
								<option value="CLEARANCE">CLEARANCE</option>
								<option value="ESCAPE_VELOCITY">ESCAPE_VELOCITY</option>
								<option value="BEACON">BEACON</option>
								<option value="SPRINT_CORE">SPRINT_CORE</option>
								<option value="SURGE_BASE">SURGE_BASE</option>
								<option value="FULL_CONSTELLATION">FULL_CONSTELLATION</option>
							</select>
							<div
								class="absolute right-3 top-1/2 -translate-y-1/2 pointer-events-none opacity-50"
							>
								<svg
									width="10"
									height="6"
									viewBox="0 0 10 6"
									fill="none"
									xmlns="http://www.w3.org/2000/svg"
								>
									<path
										d="M1 1L5 5L9 1"
										stroke="currentColor"
										stroke-width="1.5"
										stroke-linecap="round"
										stroke-linejoin="round"></path>
								</svg>
							</div>
						</div>
					</div>

					<div class="space-y-2">
						<label
							for="message"
							class="text-sm font-medium text-neutral-700 dark:text-neutral-300 font-mono"
						>
							Payload (Message) <span class="text-red-500">*</span>
						</label>
						<textarea
							id="message"
							name="message"
							rows="5"
							class="w-full my-2 px-4 py-2 rounded-md bg-neutral-100/20 dark:bg-black/30 border border-neutral-200 dark:border-white/10 text-black dark:text-white focus:outline-none focus:ring-2 focus:ring-emerald-500/50 transition-all resize-none font-mono text-sm"
							placeholder="Brief us on your mission parameters..."></textarea>
						<p id="message-error" class="text-xs text-red-400 font-mono hidden mt-1"></p>
					</div>

					<div class="flex flex-col gap-4 pt-2">
						<p class="text-sm text-emerald-800 dark:text-emerald-500 font-mono">
							Prefer establishing a direct protocol? Route your secure comms to <a
								href="mailto:hi@auroryslabs.com"
								class="font-semibold underline underline-offset-2 hover:text-emerald-500 dark:hover:text-emerald-400 transition-colors"
								>hi@auroryslabs.com</a
							>
						</p>
						<div
							class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 w-full"
						>
							<div class="flex flex-col gap-1">
								<!-- Turnstile Widget Container -->
								<div
									id="cf-turnstile"
									class="cf-turnstile"
									data-sitekey="1x00000000000000000000AA"
									data-theme="dark"
								>
								</div>
								<p
									class="text-xs text-neutral-700 dark:text-neutral-500 font-mono pl-1"
								>
									0% Spam Probability. Secured by Turnstile.
								</p>
							</div>
							<button
								id="submit-button"
								type="submit"
								class="relative cursor-pointer group transition-all animate-rainbow inline-flex items-center justify-center gap-2 shrink-0 rounded-xl outline-none focus-visible:ring-[3px] focus-visible:ring-[var(--ring)] text-sm font-semibold whitespace-nowrap disabled:pointer-events-none disabled:opacity-50 hover:-translate-y-1 hover:scale-105 h-11 px-8 border-0 bg-backdrop-blur-md bg-[linear-gradient(#090909,#121212),linear-gradient(#090909_50%,rgba(18,18,19,0.6)_80%,rgba(18,18,19,0)),linear-gradient(90deg,var(--color-1),var(--color-5),var(--color-3),var(--color-4),var(--color-2),var(--color-1))] bg-[length:200%] text-white [background-clip:padding-box,border-box,border-box] [background-origin:border-box] [border:calc(0.175rem)_solid_transparent] before:absolute before:bottom-[-20%] before:left-1/2 before:z-0 before:h-1/5 before:w-3/5 before:-translate-x-1/2 before:animate-rainbow before:bg-[linear-gradient(90deg,var(--color-1),var(--color-5),var(--color-3),var(--color-4),var(--color-2),var(--color-1))] before:bg-[length:200%] before:[filter:blur(1rem)] w-full sm:w-auto"
							>
								<span id="submit-text" class="relative z-10">Transmit Securely</span>
							</button>
						</div>
					</div>
				</form>
			</div>
		</div>
	</div>
</section>

<script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer
></script>

<script>
	import confetti from 'canvas-confetti';
	import { z } from 'zod';

	const TEMPLATES: Record<string, string> = {
		PING_HELLO:
			"Hi Aurorys,\n\nI've been following your work and really like your approach. I wanted to reach out regarding my current setup.\n\nMy product is essentially _______, and I'd love some advice on scalability and architecture. Looking forward to chatting!",
		FIRST_LIGHT:
			"Hi Aurorys,\n\nI would like to initiate a First Light Security Posture Assessment for our organization.\n\nOur current team size is ______, and our primary application runs on _______. We want to identify critical gaps and map out our remediation priorities.",
		FOUNDATION:
			"Hi Aurorys,\n\nWe are building a new system for _______ and want to design our security baseline correctly from the start.\n\nWe need a Security Architecture Blueprint. Our stack involves _______.",
		PULSE:
			"Hi Aurorys,\n\nWe want to secure our CI/CD pipeline and establish continuous automated validation.\n\nWe run our builds on _______ and deploy to _______. Let's get Pulse integrated into our workflow.",
		CLEARANCE:
			"Hi Aurorys,\n\nOur clients are requesting SOC 2 / compliance proof. We need to prepare for compliance readiness.\n\nOur target audit timeline is _______, and we need guidance mapping our controls.",
		ESCAPE_VELOCITY:
			"Hi Aurorys,\n\nOur cloud bills are escalating and we want to gain sovereign ownership of our infrastructure.\n\nWe are looking to migrate from _______ to a hybrid/on-prem/colocated topology.",
		BEACON:
			"Hi Aurorys,\n\nWe need senior fractional security advisory. We are looking for ongoing guidance for our engineering decisions.",
		SPRINT_CORE:
			"Hi Aurorys,\n\nWe have a specific security problem in _______ that requires immediate focus in a 2-week Sprint.",
		SURGE_BASE:
			"Hi Aurorys,\n\nWe want to deploy a hardened, production-ready infrastructure stack in days using Surge.\n\nOur infrastructure will run on _______ hardware/compute environment.",
		FULL_CONSTELLATION:
			"Hi Aurorys,\n\nWe want to establish a complete security constellation. We want the full 6-month security transformation program (assessment, architecture, pipeline, compliance, and advisory).",
	};

	const placeholders: Record<string, string> = {
		PING_HELLO: 'Brief us on your mission parameters...',
		FIRST_LIGHT: 'Tell us about your team size, tech stack, and assessment goals...',
		FOUNDATION: 'What platform are you building? Share your stack and architecture goals...',
		PULSE: 'What CI/CD tools do you use and what are your automation priorities...',
		CLEARANCE: 'What is your target compliance standard (SOC 2, ISO, etc.) and audit timeline...',
		ESCAPE_VELOCITY: 'Tell us about your current cloud provider and your sovereignty goals...',
		BEACON: 'Describe your advisory needs and engineering team profile...',
		SPRINT_CORE: 'Describe the specific problem or scope you want to address in a Sprint...',
		SURGE_BASE: 'What hardware or compute environment will host your Surge infrastructure stack...',
		FULL_CONSTELLATION: 'Tell us about your team size, product scope, and transformation timeline...',
	};

	const contactSchema = z.object({
		name: z.string().min(2, { message: 'Identity name must be at least 2 characters.' }),
		email: z.string().email({ message: 'Coordinates must represent a valid email format.' }),
		message: z.string().min(10, { message: 'Payload description must contain at least 10 characters.' }),
	});

	document.addEventListener('DOMContentLoaded', () => {
		const subjectSelect = document.getElementById(
			'subject',
		) as HTMLSelectElement;
		const messageTextarea = document.getElementById(
			'message',
		) as HTMLTextAreaElement;
		const form = document.getElementById('contact-form') as HTMLFormElement;
		const overlay = document.getElementById('success-overlay');
		const submitBtn = document.getElementById(
			'submit-button',
		) as HTMLButtonElement;
		const submitText = document.getElementById('submit-text');
		const resetBtn = document.getElementById('reset-button');

		const nameInput = document.getElementById('name') as HTMLInputElement;
		const emailInput = document.getElementById('email') as HTMLInputElement;

		const nameError = document.getElementById('name-error') as HTMLParagraphElement;
		const emailError = document.getElementById('email-error') as HTMLParagraphElement;
		const messageError = document.getElementById('message-error') as HTMLParagraphElement;

		function validateField(field: 'name' | 'email' | 'message', value: string) {
			const inputEl = field === 'name' ? nameInput : field === 'email' ? emailInput : messageTextarea;
			const errorEl = field === 'name' ? nameError : field === 'email' ? emailError : messageError;
			if (!inputEl) return true;

			let result;
			if (field === 'name') {
				result = contactSchema.pick({ name: true }).safeParse({ name: value });
			} else if (field === 'email') {
				result = contactSchema.pick({ email: true }).safeParse({ email: value });
			} else {
				result = contactSchema.pick({ message: true }).safeParse({ message: value });
			}

			if (!result.success) {
				const errorMsg = result.error.errors[0]?.message || 'Invalid entry';
				inputEl.classList.add('border-red-500', 'focus:ring-red-500/50');
				inputEl.classList.remove('border-neutral-200', 'dark:border-white/10', 'focus:ring-emerald-500/50');
				if (errorEl) {
					errorEl.innerText = errorMsg;
					errorEl.classList.remove('hidden');
				}
				return false;
			} else {
				inputEl.classList.remove('border-red-500', 'focus:ring-red-500/50');
				inputEl.classList.add('border-neutral-200', 'dark:border-white/10');
				errorEl?.classList.add('hidden');
				return true;
			}
		}

		nameInput?.addEventListener('blur', () => validateField('name', nameInput.value));
		nameInput?.addEventListener('input', () => {
			if (nameError && !nameError.classList.contains('hidden')) {
				validateField('name', nameInput.value);
			}
		});

		emailInput?.addEventListener('blur', () => validateField('email', emailInput.value));
		emailInput?.addEventListener('input', () => {
			if (emailError && !emailError.classList.contains('hidden')) {
				validateField('email', emailInput.value);
			}
		});

		messageTextarea?.addEventListener('blur', () => validateField('message', messageTextarea.value));
		messageTextarea?.addEventListener('input', () => {
			if (messageError && !messageError.classList.contains('hidden')) {
				validateField('message', messageTextarea.value);
			}
		});

		function parseParams(queryStr: string) {
			const params = new URLSearchParams(queryStr);
			const subjectParam = params.get('subject');
			const messageParam = params.get('message');

			if (subjectSelect && subjectParam && Object.keys(TEMPLATES).includes(subjectParam)) {
				subjectSelect.value = subjectParam;
				if (messageTextarea) {
					messageTextarea.placeholder = placeholders[subjectParam] || placeholders['PING_HELLO'];
					messageTextarea.value = messageParam || TEMPLATES[subjectParam];
				}
			}
		}

		// Initial query param parse
		if (window.location.search) {
			parseParams(window.location.search);
		}

		// Handle hash params for local single page anchors (e.g. #contact?subject=SURGE_BASE)
		const checkHash = () => {
			const hash = window.location.hash;
			if (hash.startsWith('#contact') && hash.includes('?')) {
				const queryPart = hash.slice(hash.indexOf('?'));
				parseParams(queryPart);
			}
		};

		checkHash();
		window.addEventListener('hashchange', checkHash);

		subjectSelect?.addEventListener('change', (e) => {
			const val = (e.target as HTMLSelectElement).value;
			if (messageTextarea) {
				messageTextarea.placeholder =
					placeholders[val] || placeholders['PING_HELLO'];
				// Auto-fill template if empty or if it matches another template
				const currentVal = messageTextarea.value.trim();
				const isDefaultTemplate = Object.values(TEMPLATES).some(t => t.trim() === currentVal);
				if (!currentVal || isDefaultTemplate) {
					messageTextarea.value = TEMPLATES[val];
				}
			}
		});

		resetBtn?.addEventListener('click', () => {
			form?.reset();
			// Clear error states
			[nameInput, emailInput, messageTextarea].forEach((input) => {
				input?.classList.remove('border-red-500', 'focus:ring-red-500/50');
				input?.classList.add('border-neutral-200', 'dark:border-white/10');
			});
			[nameError, emailError, messageError].forEach((err) => err?.classList.add('hidden'));

			overlay?.classList.remove('flex');
			overlay?.classList.add('hidden');
		});

		form?.addEventListener('submit', async (e) => {
			e.preventDefault();

			const nameVal = nameInput?.value || '';
			const emailVal = emailInput?.value || '';
			const messageVal = messageTextarea?.value || '';

			const isNameValid = validateField('name', nameVal);
			const isEmailValid = validateField('email', emailVal);
			const isMessageValid = validateField('message', messageVal);

			if (!isNameValid || !isEmailValid || !isMessageValid) {
				return;
			}

			const validationResult = contactSchema.safeParse({
				name: nameVal,
				email: emailVal,
				message: messageVal,
			});

			if (!validationResult.success) {
				return;
			}

			const turnstileResponse = (
				document.querySelector(
					'[name="cf-turnstile-response"]',
				) as HTMLInputElement
			)?.value;
			if (!turnstileResponse) {
				alert('Security verification is pending. Please wait.');
				return;
			}

			if (submitBtn) submitBtn.disabled = true;
			if (submitText) submitText.innerText = 'Transmitting...';

			try {
				const formData = new FormData(form);
				const data = Object.fromEntries(formData.entries());

				// Simulate network delay
				await new Promise((r) => setTimeout(r, 1000));

				// Show Success UI
				overlay?.classList.remove('hidden');
				overlay?.classList.add('flex');

				// Confetti
				const duration = 3 * 1000;
				const animationEnd = Date.now() + duration;
				const defaults = {
					startVelocity: 30,
					spread: 360,
					ticks: 60,
					zIndex: 50,
				};

				const randomInRange = (min: number, max: number) =>
					Math.random() * (max - min) + min;

				const interval: any = setInterval(() => {
					const timeLeft = animationEnd - Date.now();
					if (timeLeft <= 0) return clearInterval(interval);
					const particleCount = 50 * (timeLeft / duration);
					confetti({
						...defaults,
						particleCount,
						origin: { x: randomInRange(0.1, 0.3), y: Math.random() - 0.2 },
					});
					confetti({
						...defaults,
						particleCount,
						origin: { x: randomInRange(0.7, 0.9), y: Math.random() - 0.2 },
					});
				}, 250);
			} catch (err) {
				console.error(err);
				alert(
					'Failed to transmit securely. Please try routing directly via email.',
				);
			} finally {
				if (submitBtn) submitBtn.disabled = false;
				if (submitText) submitText.innerText = 'Transmit Securely';
			}
		});
	});
</script>

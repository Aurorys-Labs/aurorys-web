---
const footerLinks = {
  product: [
    { label: "Our Solutions", href: "/solutions" },
    { label: "Your Path", href: "/pricing" },
    { label: "The Aurorys Way", href: "#aurorys-way" },
    { label: "Trust Center", href: "/trust" },
  ],
  company: [
    { label: "Roots", href: "/roots" },
    { label: "How We Work", href: "/how-we-work" },
    { label: "Contact", href: "/?subject=PING_HELLO#contact" },
    { label: "Blog", href: "/blog" },
    { label: "Security Checklist", href: "/security-checklist" },
  ],
  legal: [
    { label: "Privacy Policy", href: "/legal/privacy" },
    { label: "Terms of Service", href: "/legal/terms" },
    { label: "Cookie Policy", href: "/legal/cookies" },
  ],
};
---

<footer class="border-t border-[var(--border-default)]">
  <div class="content-width py-16">
    <!-- Divider -->
    <div class="flex justify-center py-4 mb-12">
      <img src="/images/logos/golden divider.svg" alt="" class="w-full max-w-2xl h-[2px] opacity-60" />
    </div>

    <!-- Main footer grid -->
    <div class="grid grid-cols-1 md:grid-cols-12 gap-10 md:gap-8">
      <!-- Brand column — spans 5 cols -->
      <div class="md:col-span-5">
        <div class="flex items-center gap-3 mb-4">
          <img src="/images/logos/normal updated colors.svg" alt="Aurorys Labs" class="h-8 w-auto" />
          <span class="font-semibold text-lg tracking-tight">Aurorys Labs</span>
        </div>
        <p class="text-sm text-[var(--text-muted)] max-w-sm leading-relaxed mb-4">
          Premium boutique cybersecurity consulting. We design secure, resilient, and sovereign digital infrastructure for organizations that value their independence.
        </p>
        <p class="text-sm font-semibold text-[var(--text-stellar)] mb-6">
          Security capability, not dependency.
        </p>
        <a href="mailto:contact@auroryslabs.com" class="text-sm text-[var(--aurora-green-solid)] hover:underline">
          contact@auroryslabs.com
        </a>
      </div>

      <!-- Right side navigation columns wrapped in glass card -->
      <div class="md:col-span-7 glass-card p-8 grid grid-cols-1 md:grid-cols-7 gap-8">
        <!-- Product column -->
        <div class="md:col-span-2">
          <h4 class="font-semibold text-sm mb-4 text-[var(--text-stellar)]">Product</h4>
          <ul class="space-y-2.5">
            {footerLinks.product.map((link) => (
              <li><a href={link.href} class="text-sm text-[var(--text-muted)] hover:text-[var(--text-stellar)] transition-colors">{link.label}</a></li>
            ))}
          </ul>
        </div>

        <!-- Company column -->
        <div class="md:col-span-2">
          <h4 class="font-semibold text-sm mb-4 text-[var(--text-stellar)]">Company</h4>
          <ul class="space-y-2.5">
            {footerLinks.company.map((link) => (
              <li><a href={link.href} class="text-sm text-[var(--text-muted)] hover:text-[var(--text-stellar)] transition-colors">{link.label}</a></li>
            ))}
          </ul>
        </div>

        <!-- Legal column -->
        <div class="md:col-span-3">
          <h4 class="font-semibold text-sm mb-4 text-[var(--text-stellar)]">Legal</h4>
          <ul class="space-y-2.5">
            {footerLinks.legal.map((link) => (
              <li><a href={link.href} class="text-sm text-[var(--text-muted)] hover:text-[var(--text-stellar)] transition-colors">{link.label}</a></li>
            ))}
          </ul>
        </div>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="border-t border-[var(--border-default)] mt-12 pt-8 flex flex-col md:flex-row justify-between items-center gap-4">
      <p class="text-xs text-[var(--text-faint)]">
        &copy; 2026 Aurorys Labs. All rights reserved.
      </p>
      <p class="text-xs text-[var(--text-faint)]">
        Built with ♥ for people, not just systems.
      </p>
    </div>
  </div>
</footer>
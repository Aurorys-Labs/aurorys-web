---
import BaseLayout from "../layouts/BaseLayout.astro";
import "../styles/global.css";
import ContactSection from "../components/ContactSection.astro";
import Footer from "../components/astro/Footer.astro";
import { AuroraOverlay } from "../components/react/AuroraOverlay";
import { MobileNav } from "../components/react/MobileNav";
import { Navbar } from "../components/react/Navbar";
import { BlogHub } from "../components/react/blog/BlogHub";

import blogPosts from "../lib/data/blog-posts.json";
---

<BaseLayout title="Blog | Insights & Methodology | Aurorys Labs">
  <div class="fixed inset-0 -z-20">
    <div
      class="w-full h-full"
      style="background-image: url('/images/astrophotography/astro-image11.webp'); background-size: cover; background-position: center;"
    ></div>
    <div class="absolute inset-0 bg-gradient-to-b from-[var(--bg-primary)]/40 via-[var(--bg-primary)]/35 to-[var(--bg-primary)]/75"></div>
  </div>

  {/* Ambient background glows for color and premium look */}
  <div class="absolute top-[20%] left-[10%] w-[35rem] h-[35rem] rounded-full bg-[var(--color-3)]/10 blur-[150px] pointer-events-none z-0 animate-pulse" style="animation-duration: 10s;"></div>
  <div class="absolute top-[45%] right-[5%] w-[40rem] h-[40rem] rounded-full bg-[var(--color-1)]/10 blur-[150px] pointer-events-none z-0 animate-pulse" style="animation-duration: 15s;"></div>
  <div class="absolute bottom-[20%] left-[15%] w-[30rem] h-[30rem] rounded-full bg-[var(--color-2)]/10 blur-[150px] pointer-events-none z-0 animate-pulse" style="animation-duration: 12s;"></div>

  <AuroraOverlay client:load />
  <Navbar client:load />
  <MobileNav client:load />

  {/* Page Hero */}
  <section class="relative z-10 pt-32 pb-12 md:pt-40 md:pb-16">
    <div class="content-width mx-auto px-6 text-center">
      <div class="max-w-3xl mx-auto space-y-6">
        <h1 class="font-sans font-bold text-4xl md:text-5xl lg:text-6xl text-gradient-aurora tracking-tight leading-tight mb-6">
          Insights & Blueprint Methodology
        </h1>
        <p class="font-serif italic text-xl md:text-2xl text-[var(--text-stellar)] leading-relaxed">
          Technical posts, infrastructure guides, and transparency reports for engineering teams.
        </p>
      </div>
    </div>
  </section>

  {/* Interactive Blog Hub (Search, Category/Tag Filtering, Pagination) */}
  <section class="relative z-10 py-16 border-t border-white/[0.04]">
    <div class="content-width mx-auto px-6 animate-fade-in">
      <BlogHub posts={blogPosts} client:load />
    </div>
  </section>

  <ContactSection />
  <Footer />
</BaseLayout>

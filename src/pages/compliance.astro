---
import BaseLayout from "../layouts/BaseLayout.astro";
import "../styles/global.css";
import ContactSection from "../components/ContactSection.astro";
import Footer from "../components/astro/Footer.astro";
import { AuroraOverlay } from "../components/react/AuroraOverlay";
import { MobileNav } from "../components/react/MobileNav";
import { Navbar } from "../components/react/Navbar";
import { ComplianceOfferings } from "../components/react/compliance/ComplianceOfferings";
import { ComplianceTimeline } from "../components/react/compliance/ComplianceTimeline";
import { FastTrackPills } from "../components/react/compliance/FastTrackPills";
import { GRCPillar } from "../components/react/compliance/GRCPillar";
import { TableOfContents } from "../components/react/compliance/TableOfContents";
import { InteractiveGlowButton } from "../components/ui/interactive-glow-button";
import { RainbowButton } from "../components/ui/rainbow-button";

import complianceData from "../lib/data/compliance-hub.json";
---

<BaseLayout title={`${complianceData.hero.title} | Aurorys Labs`}>
  <div class="fixed inset-0 -z-20">
    <div
      class="w-full h-full"
      style="background-image: url('/images/astrophotography/astro-image5.webp'); background-size: cover; background-position: center;"
    ></div>
    <div class="absolute inset-0 bg-gradient-to-b from-[var(--bg-primary)]/40 via-[var(--bg-primary)]/35 to-[var(--bg-primary)]/75"></div>
  </div>

  <AuroraOverlay client:load />
  <Navbar client:load />
  <MobileNav client:load />

  {/* Page Hero */}
  <section class="relative z-10 pt-32 pb-12 md:pt-40 md:pb-16">
    <div class="content-width px-6 text-center space-y-8">
      <div class="max-w-4xl mx-auto space-y-6">
        <h1 class="font-sans font-bold text-4xl md:text-5xl lg:text-6xl text-gradient-aurora tracking-tight leading-tight">
          {complianceData.hero.title}
        </h1>
        <p class="font-serif italic text-xl md:text-2xl text-[var(--text-stellar)] max-w-3xl mx-auto leading-relaxed">
          {complianceData.hero.subtitle}
        </p>
      </div>

      <FastTrackPills options={complianceData.fastTrackOptions} client:load />
    </div>
  </section>

  {/* Main Layout Grid */}
  <section class="relative z-10 py-12 border-t border-white/[0.04]">
    <div class="content-width px-6">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 items-start">

        {/* Left Sidebar Table of Contents */}
        <div class="lg:col-span-3 lg:sticky lg:top-28 hidden lg:block">
          <TableOfContents
            items={[
              { id: "grc-explained", label: "GRC Explained" },
              { id: "roi", label: "Compliance ROI" },
              { id: "offerings", label: "Compliance Programs" },
              { id: "timeline", label: "Delivery Timeline" }
            ]}
            client:load
          />
        </div>

        {/* Right Main Content Column */}
        <div class="lg:col-span-9 space-y-20">

          {/* Section 1: GRC Explained */}
          <div id="grc-explained" class="scroll-mt-28 space-y-12 text-center lg:text-left">
            <div class="max-w-3xl space-y-4">
              <h2 class="font-sans font-bold text-3xl md:text-4xl tracking-tight text-[var(--text-stellar)]">
                {complianceData.grcExplained.title}
              </h2>
              <p class="text-white/60 text-base font-sans leading-relaxed">
                {complianceData.grcExplained.subtitle}
              </p>
            </div>

            <GRCPillar pillars={complianceData.grcExplained.pillars} client:load />

            {/* GRC System Note & Display Scale Prestige Statement */}
            <div class="space-y-8 border-t border-white/[0.06] pt-12 mt-8 text-center">
              <div class="glass-card p-10 md:p-16 relative overflow-hidden rounded-3xl border border-white/[0.06] bg-[rgba(13,17,23,0.3)] backdrop-blur-xl">
                <div class="absolute inset-0 bg-[var(--aurora-green-solid)]/5 blur-3xl opacity-30 rounded-full" />
                <blockquote class="font-serif italic text-2xl md:text-4xl text-[var(--text-stellar)] max-w-2xl mx-auto relative z-10 text-shadow-sm">
                  "Compliance without governance is theater."
                </blockquote>
              </div>
              <p class="text-white/60 text-sm leading-relaxed max-w-2xl mx-auto font-sans italic">
                {complianceData.grcExplained.systemNote}
              </p>
            </div>
          </div>

          {/* Section 2: ROI */}
          <div id="roi" class="scroll-mt-28 pt-16 border-t border-white/[0.04] text-left space-y-12">
            <div class="max-w-3xl">
              <h2 class="font-sans font-bold text-3xl md:text-4xl tracking-tight text-[var(--text-stellar)] mb-4">
                {complianceData.roiSection.title}
              </h2>
              <p class="text-white/60 text-base font-sans leading-relaxed">
                Compliance is more than a compliance scorecard. It is a fundamental property of a secure, sovereign cybersecurity organization.
              </p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 text-left">
              {complianceData.roiSection.items.map((item) => (
                <div class="glass-card p-6 rounded-xl border border-white/[0.06] backdrop-blur-md bg-[rgba(13,17,23,0.25)] space-y-3 hover:border-white/[0.12] transition-colors group">
                  <h3 class="font-heading font-medium text-lg text-[var(--text-stellar)] group-hover:text-[var(--aurora-green-solid)] transition-colors">
                    {item.title}
                  </h3>
                  <p class="text-white/70 text-sm leading-relaxed font-sans">
                    {item.description}
                  </p>
                </div>
              ))}
            </div>
          </div>

          {/* Section 3: Offerings */}
          <div id="offerings" class="scroll-mt-28 pt-16 border-t border-white/[0.04] text-left space-y-12">
            <div class="max-w-3xl">
              <h2 class="font-sans font-bold text-3xl md:text-4xl tracking-tight text-[var(--text-stellar)] mb-4">
                Compliance Programs
              </h2>
              <p class="text-white/60 text-base font-sans leading-relaxed">
                We help you build the operational foundation, policies, and remediation roadmap to achieve compliance.
              </p>
            </div>
            <ComplianceOfferings offerings={complianceData.offerings} client:load />
          </div>

          {/* Section 4: Timeline */}
          <div id="timeline" class="scroll-mt-28 pt-16 border-t border-white/[0.04] text-left space-y-12">
            <div class="max-w-3xl">
              <h2 class="font-sans font-bold text-3xl md:text-4xl tracking-tight text-[var(--text-stellar)] mb-4">
                {complianceData.timeline.title}
              </h2>
              <p class="text-white/60 text-base font-sans leading-relaxed">
                {complianceData.timeline.subtitle}
              </p>
            </div>
            <ComplianceTimeline timelineData={complianceData.timeline} client:load />
          </div>

        </div>
      </div>
    </div>
  </section>

  {/* Cross Links & CTA */}
  <section class="relative z-10 py-20 border-t border-white/[0.04] text-center bg-black/10">
    <div class="content-width px-6">
      <h3 class="font-sans font-bold text-3xl md:text-4xl tracking-tight text-[var(--text-stellar)] mb-8">
        {complianceData.crossLinks.title}
      </h3>
      <div class="flex flex-col sm:flex-row gap-4 justify-center max-w-2xl mx-auto">
        <RainbowButton variant="glass" size="lg" className="rounded-xl justify-center w-full sm:w-auto" asChild>
          <a href="/solutions">Explore All Solutions</a>
        </RainbowButton>
        <InteractiveGlowButton href="/how-we-work" className="justify-center w-full sm:w-auto">
          How We Work
        </InteractiveGlowButton>
        <RainbowButton variant="glass" size="lg" className="rounded-xl justify-center w-full sm:w-auto" asChild>
          <a
            href="#contact?subject=CLEARANCE"
            onClick={(e) => {
              e.preventDefault();
              const contactSection = document.getElementById("contact");
              if (contactSection) {
                const select = document.getElementById("subject") as HTMLSelectElement | null;
                if (select) {
                  select.value = "CLEARANCE";
                  select.dispatchEvent(new Event("change"));
                }
                contactSection.scrollIntoView({ behavior: "smooth" });
              }
            }}
          >
            Book Discovery Call
          </a>
        </RainbowButton>
      </div>
    </div>
  </section>

  <ContactSection />
  <Footer />
</BaseLayout>

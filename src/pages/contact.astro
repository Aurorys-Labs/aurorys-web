---
import BaseLayout from "../layouts/BaseLayout.astro";
import "../styles/global.css";
import ContactSection from "../components/ContactSection.astro";
import Footer from "../components/astro/Footer.astro";
import { AuroraOverlay } from "../components/react/AuroraOverlay";
import { MobileNav } from "../components/react/MobileNav";
import { Navbar } from "../components/react/Navbar";

const explorationLinks = [
	{
		label: "See How We Assess",
		desc: "Read about our First Light methodology.",
		href: "/how-we-work",
	},
	{
		label: "Explore Security Paths",
		desc: "Compare engagement packages and sizing.",
		href: "/security-paths",
	},
	{
		label: "Understand GRC Pillars",
		desc: "Learn about Governance, Risk, and Compliance.",
		href: "/compliance",
	},
	{
		label: "Read Our Roots",
		desc: "Our commitment toDigital Sovereignty.",
		href: "/roots",
	},
];
---

<BaseLayout title="Contact Us | Aurorys Labs">
  <div class="fixed inset-0 -z-20">
    <div
      class="w-full h-full"
      style="background-image: url('/images/astrophotography/astro-image7.webp'); background-size: cover; background-position: center;"
    ></div>
    <div class="absolute inset-0 bg-gradient-to-b from-[var(--bg-primary)]/40 via-[var(--bg-primary)]/35 to-[var(--bg-primary)]/75"></div>
  </div>

  <AuroraOverlay client:load />
  <Navbar client:load />
  <MobileNav client:load />

  {/* Dedicated Contact Hero Banner */}
  <section class="relative z-10 pt-32 pb-6 md:pt-40 md:pb-8">
    <div class="content-width mx-auto px-6 text-center space-y-6">
      <h1 class="font-sans font-bold text-4xl md:text-5xl lg:text-6xl text-gradient-aurora leading-tight tracking-tight mb-6">
        Secure Uplink
      </h1>
      <p class="font-serif italic text-xl md:text-2xl text-[var(--text-stellar)] max-w-3xl mx-auto leading-relaxed">
        Ready to build security capability rather than dependency? Establish a secure connection below.
      </p>
    </div>
  </section>

  {/* The Engagement Protocol */}
  <section class="relative z-10 py-12">
    <div class="content-width mx-auto px-6">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-5xl mx-auto">
        <div class="glass-card p-6 rounded-2xl border border-white/[0.06] bg-[rgba(13,17,23,0.25)] space-y-3 hover:border-white/[0.12] transition-colors">
          <div class="w-10 h-10 rounded-full bg-[var(--aurora-blue-solid)]/10 flex items-center justify-center text-[var(--aurora-blue-solid)] mb-4">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>
          </div>
          <h3 class="font-heading font-semibold text-lg text-[var(--text-stellar)]">1. Signal Received</h3>
          <p class="text-white/60 text-sm leading-relaxed font-sans">
            We review your mission parameters and typically respond within 24 hours to schedule an initial discovery protocol.
          </p>
        </div>

        <div class="glass-card p-6 rounded-2xl border border-white/[0.06] bg-[rgba(13,17,23,0.25)] space-y-3 hover:border-white/[0.12] transition-colors">
          <div class="w-10 h-10 rounded-full bg-[var(--aurora-purple-solid)]/10 flex items-center justify-center text-[var(--aurora-purple-solid)] mb-4">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
          </div>
          <h3 class="font-heading font-semibold text-lg text-[var(--text-stellar)]">2. Tactical Scoping</h3>
          <p class="text-white/60 text-sm leading-relaxed font-sans">
            A focused discussion to map your exact requirements, from immediate sprint needs to full-scale infrastructure deployments.
          </p>
        </div>

        <div class="glass-card p-6 rounded-2xl border border-white/[0.06] bg-[rgba(13,17,23,0.25)] space-y-3 hover:border-white/[0.12] transition-colors">
          <div class="w-10 h-10 rounded-full bg-[var(--aurora-green-solid)]/10 flex items-center justify-center text-[var(--aurora-green-solid)] mb-4">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>
          </div>
          <h3 class="font-heading font-semibold text-lg text-[var(--text-stellar)]">3. Execution Plan</h3>
          <p class="text-white/60 text-sm leading-relaxed font-sans">
            We provide a clear, bound blueprint or sprint format. No vague retainer hours—just concrete deliverables and timelines.
          </p>
        </div>
      </div>
    </div>
  </section>

  {/* Main Contact Section */}
  <div class="relative z-10 pb-16">
    <ContactSection hideHeader={true} />
  </div>

  {/* Not ready to talk? Section */}
  <section class="relative z-10 py-16 border-t border-white/[0.04] bg-black/10">
    <div class="content-width mx-auto px-6">
      <div class="max-w-4xl mx-auto text-center space-y-12">
        <div class="space-y-4">
        <h2 class="font-sans font-bold text-3xl md:text-4xl tracking-tight text-[var(--text-stellar)]">
          Not ready to talk yet?
        </h2>
        <p class="text-[var(--text-muted)] text-[var(--text-body)] font-sans max-w-xl mx-auto">
          No hard sell. No pressure. Here's what to explore instead to understand how we operate.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 text-left">
        {explorationLinks.map((item) => (
          <a
            href={item.href}
            class="glass-card p-6 rounded-xl border border-white/[0.06] backdrop-blur-md bg-[rgba(13,17,23,0.25)] space-y-2 hover:border-white/[0.12] transition-colors group"
          >
            <h3 class="font-sans font-bold text-lg text-[var(--text-stellar)] group-hover:text-[var(--aurora-green-solid)] transition-colors flex items-center gap-1.5">
              {item.label}
              <svg class="w-4 h-4 transition-transform group-hover:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
              </svg>
            </h3>
            <p class="text-white/60 text-sm leading-relaxed font-sans">
              {item.desc}
            </p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>

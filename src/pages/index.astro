---
import "../styles/global.css";
import { Badge } from "@/components/ui/badge";
import { Button } from "@/components/ui/button";
import { RainbowButtonDemo } from "../components/RainbowButtonDemo";
---

<html lang="en" class="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Aurorys Labs — Dependency Verification</title>
    <style>
      body { margin: 0; padding: 0; overflow-x: hidden; }
    </style>
  </head>
  <body class="bg-background text-foreground font-sans min-h-[100dvh] antialiased">
    <div class="fixed inset-0 -z-20" style="background-image: url('/images/astrophotography/astro-image1.webp'); background-size: cover; background-position: center;"></div>
    <div class="fixed inset-0 -z-10 bg-background/60"></div>

    <main class="relative z-10 max-w-3xl mx-auto px-6 py-16" style="display: flex; flex-direction: column; gap: 3rem;">
      <h1 class="text-5xl font-bold gradient-text" style="background: linear-gradient(135deg, #00e8a0, #a78bfa); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">
        Dependency Verification
      </h1>

      <div class="glass-card">
        <h2 class="text-xl font-semibold mb-3">Glass Card via Tailwind</h2>
        <p class="text-muted-foreground text-sm mb-4" style="max-width: 40rem;">
          This card uses Tailwind utility classes: backdrop-blur, border-white/10, bg-white/3.
          If you see blurred glass over the astrophotograph, Tailwind works.
        </p>
        <div style="display: flex; gap: 0.75rem; flex-wrap: wrap;">
          <Button client:load variant="default">shadcn Button</Button>
          <Button client:load variant="outline">Outline</Button>
          <Badge client:load variant="secondary">shadcn Badge</Badge>
        </div>
      </div>

      <div class="glass-card">
        <h2 class="text-xl font-semibold mb-3">Rainbow Button — ported from old-nextjs</h2>
        <p class="text-muted-foreground text-sm mb-4" style="max-width: 40rem;">
          Uses Radix Slot, CVA, and animate-rainbow keyframe. Should show animated gradient border.
        </p>
        <RainbowButtonDemo client:load />
      </div>

      <div class="glass-card">
        <h2 class="text-xl font-semibold mb-3">Font Verification</h2>
        <p class="font-sans text-lg mb-2">Geist Sans (variable): The quick brown fox jumps over the lazy dog.</p>
        <p class="font-mono text-lg mb-2">Geist Mono (variable): const verify = () => true;</p>
        <p class="text-lg" style="font-family: 'Instrument Serif', serif; font-style: italic;">
          Instrument Serif Italic: Security by Design. Premium boutique consulting.
        </p>
      </div>

      <div class="glass-card">
        <h2 class="text-xl font-semibold mb-3">Stack Status</h2>
        <div style="display: flex; flex-direction: column; gap: 0.5rem;">
          <div style="display: flex; justify-content: space-between; padding: 0.5rem 0; border-bottom: 1px solid rgba(255,255,255,0.05);">
            <span>Astro 5.x + React 19</span>
            <Badge client:load variant="secondary">Island Active</Badge>
          </div>
          <div style="display: flex; justify-content: space-between; padding: 0.5rem 0; border-bottom: 1px solid rgba(255,255,255,0.05);">
            <span>Tailwind CSS 4</span>
            <Badge client:load variant="secondary">Glass Card Renders</Badge>
          </div>
          <div style="display: flex; justify-content: space-between; padding: 0.5rem 0; border-bottom: 1px solid rgba(255,255,255,0.05);">
            <span>shadcn/ui</span>
            <Badge client:load variant="secondary">Button + Badge OK</Badge>
          </div>
          <div style="display: flex; justify-content: space-between; padding: 0.5rem 0; border-bottom: 1px solid rgba(255,255,255,0.05);">
            <span>Rainbow Button (port)</span>
            <Badge client:load variant="secondary">Animated</Badge>
          </div>
          <div style="display: flex; justify-content: space-between; padding: 0.5rem 0; border-bottom: 1px solid rgba(255,255,255,0.05);">
            <span>Custom Fonts</span>
            <Badge client:load variant="secondary">Geist + Serif</Badge>
          </div>
          <div style="display: flex; justify-content: space-between; padding: 0.5rem 0;">
            <span>Astrophotograph Background</span>
            <Badge client:load variant="secondary">WebP Loaded</Badge>
          </div>
        </div>
      </div>
    </main>
  </body>
</html>

<style>
  .glass-card {
    border-radius: 1.5rem;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-top: 1.5px solid rgba(255, 255, 255, 0.2);
    padding: 2rem;
    -webkit-backdrop-filter: blur(24px) saturate(150%);
    backdrop-filter: blur(24px) saturate(150%);
    background: rgba(255, 255, 255, 0.03);
  }
</style>

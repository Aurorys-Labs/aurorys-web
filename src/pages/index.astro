---
import BaseLayout from "../layouts/BaseLayout.astro";
import "../styles/global.css";
import { HeroSlideshow } from "../components/react/HeroSlideshow";
import { AuroraOverlay } from "../components/react/AuroraOverlay";
import { Navbar } from "../components/react/Navbar";
import { MobileNav } from "../components/react/MobileNav";
import { TrustStrip } from "../components/react/TrustStrip";
import { SolutionsBento, SolutionsBentoSkeleton } from "../components/react/SolutionsBento";
import { PricingPath } from "../components/react/PricingPath";
import { AurorysWay } from "../components/react/AurorysWay";
import { HowWeWork } from "../components/react/HowWeWork";
import { BlueprintVsBuild } from "../components/react/BlueprintVsBuild";
import { Roots } from "../components/react/Roots";
import { PreFooterCTA } from "../components/react/PreFooterCTA";
import ContactSection from "../components/ContactSection.astro";
import Footer from "../components/astro/Footer.astro";
---

<BaseLayout title="Aurorys Labs | Cybersecurity Consulting and Solutions for Growing teams">
  <div class="fixed inset-0 -z-20">
    <div
      class="w-full h-full"
      style="background-image: url('/images/astrophotography/astro-image10.webp'); background-size: cover; background-position: center;"
    ></div>
    <div class="absolute inset-0 bg-gradient-to-b from-[var(--bg-primary)]/40 via-[var(--bg-primary)]/35 to-[var(--bg-primary)]/75"></div>
  </div>

  <AuroraOverlay client:load />

  <div class="absolute top-0 left-0 right-0 z-30 flex justify-center pt-20 md:pt-24">
    <a href="/contact" class="backdrop-blur-md bg-[rgba(13,17,23,0.4)] border border-white/[0.06] rounded-full px-4 py-1.5 inline-flex items-center gap-2 text-xs font-medium text-[var(--text-muted)] hover:text-[var(--text-stellar)] transition-colors">
      <span class="relative flex h-2 w-2">
        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-[var(--aurora-green-solid)] opacity-75"></span>
        <span class="relative inline-flex rounded-full h-2 w-2 bg-[var(--aurora-green-solid)]"></span>
      </span>
      Accepting Founding Clients — 15-20% off
    </a>
  </div>

  <Navbar client:load />
  <MobileNav client:load />

  <HeroSlideshow client:load />

  <TrustStrip client:load />

  <SolutionsBento client:load>
    <SolutionsBentoSkeleton slot="fallback" />
  </SolutionsBento>

  <PricingPath client:load />

  <AurorysWay client:load />

  <HowWeWork client:load />

  <BlueprintVsBuild client:load />

  <Roots client:load />

  <PreFooterCTA client:load />

  <ContactSection />

  <Footer />
</BaseLayout>
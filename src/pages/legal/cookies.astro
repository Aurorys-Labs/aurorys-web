---
import BaseLayout from "../../layouts/BaseLayout.astro";
import "../../styles/global.css";
import Footer from "../../components/astro/Footer.astro";
import { AuroraOverlay } from "../../components/react/AuroraOverlay";
import { MobileNav } from "../../components/react/MobileNav";
import { Navbar } from "../../components/react/Navbar";
---

<BaseLayout title="Cookie Policy | Aurorys Labs">
  <div class="fixed inset-0 -z-20">
    <div
      class="w-full h-full"
      style="background-image: url('/images/astrophotography/astro-image13.webp'); background-size: cover; background-position: center;"
    ></div>
    <div class="absolute inset-0 bg-gradient-to-b from-[var(--bg-primary)]/40 via-[var(--bg-primary)]/35 to-[var(--bg-primary)]/75"></div>
  </div>

  <AuroraOverlay client:load />
  <Navbar client:load />
  <MobileNav client:load />

  {/* Page Hero */}
  <section class="relative z-10 pt-32 pb-8 md:pt-40 md:pb-12">
    <div class="content-width px-6">
      <div class="max-w-4xl mx-auto text-center space-y-4">
        <h1 class="font-heading font-semibold text-4xl md:text-5xl lg:text-6xl text-gradient-aurora leading-tight tracking-tight">
          Cookie Policy
        </h1>
        <p class="text-sm font-mono text-[var(--text-muted)]">
          Last Updated: May 2026
        </p>
      </div>
    </div>
  </section>

  {/* Legal Content */}
  <section class="relative z-10 py-12 border-t border-white/[0.04] bg-black/10">
    <div class="content-width px-6">
      <div class="max-w-3xl mx-auto">
        <div class="glass-card p-8 md:p-12 rounded-3xl border border-white/[0.06] backdrop-blur-xl bg-[rgba(13,17,23,0.35)] space-y-8 text-left font-sans text-white/80 leading-relaxed">

          <div class="space-y-4">
            <h2 class="font-heading font-semibold text-xl text-[var(--text-stellar)] border-b border-white/[0.06] pb-2">1. About Cookies</h2>
            <p>
              Cookies are small text files that websites save on your computer or mobile device when you visit them.
              They are commonly used to remember preferences, analyze website traffic, and maintain session states.
            </p>
          </div>

          <div class="space-y-4">
            <h2 class="font-heading font-semibold text-xl text-[var(--text-stellar)] border-b border-white/[0.06] pb-2">2. How We Use Cookies</h2>
            <p>
              Aurorys Labs operates with a minimal privacy-first posture. We use cookies purely for essential site operation
              (such as remembering checklist choices locally or managing layout preferences). We do not run invasive marketing
              beacons or ad trackers that follow you across the web.
            </p>
          </div>

          <div class="space-y-4">
            <h2 class="font-heading font-semibold text-xl text-[var(--text-stellar)] border-b border-white/[0.06] pb-2">3. Local Storage Preference</h2>
            <p>
              Interactive elements on our site (such as the Security Checklist) store progress directly in your browser's
              local storage rather than transmitting it to our servers. This data remains completely under your control and
              never leaves your system.
            </p>
          </div>

          <div class="space-y-4">
            <h2 class="font-heading font-semibold text-xl text-[var(--text-stellar)] border-b border-white/[0.06] pb-2">4. Managing Cookies</h2>
            <p>
              You can control and/or delete cookies at any time through your browser's preference settings.
              Disabling cookies might limit some interactive functionality of our web assets, but all core
              documentation and offering information will remain accessible.
            </p>
          </div>

        </div>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>

---
import BaseLayout from "../../layouts/BaseLayout.astro";
import "../../styles/global.css";
import ContactSection from "../../components/ContactSection.astro";
import PreContact from "../../components/PreContact.astro";
import Footer from "../../components/astro/Footer.astro";
import { AuroraOverlay } from "../../components/react/AuroraOverlay";
import { MobileNav } from "../../components/react/MobileNav";
import { Navbar } from "../../components/react/Navbar";
import { RulesOfEngagement } from "../../components/react/sprints/RulesOfEngagement";
import { SprintDomainTable } from "../../components/react/sprints/SprintDomainTable";
import { SprintFormatCard } from "../../components/react/sprints/SprintFormatCard";
import { SprintVsFullTable } from "../../components/react/sprints/SprintVsFullTable";

import sprintsData from "../../lib/data/sprints-page.json";
---

<BaseLayout title={`${sprintsData.hero.title} | Aurorys Labs`}>
  <div class="fixed inset-0 -z-20">
    <div
      class="w-full h-full"
      style="background-image: url('/images/astrophotography/astro-image2.webp'); background-size: cover; background-position: center;"
    ></div>
    <div class="absolute inset-0 bg-gradient-to-b from-[var(--bg-primary)]/40 via-[var(--bg-primary)]/35 to-[var(--bg-primary)]/75"></div>
  </div>

  <AuroraOverlay client:load />
  <Navbar client:load />
  <MobileNav client:load />

  {/* Page Hero */}
  <section class="relative z-10 pt-32 pb-16 md:pt-40 md:pb-24">
    <div class="content-width px-6">
      <div class="max-w-4xl mx-auto text-center">
        <h1 class="font-heading font-semibold text-4xl md:text-5xl lg:text-6xl text-gradient-aurora mb-6 leading-tight tracking-tight">
          {sprintsData.hero.title}
        </h1>
        <p class="font-heading font-medium text-lg md:text-xl text-[var(--text-stellar)] max-w-2xl mx-auto mb-8">
          {sprintsData.hero.subtitle}
        </p>
        <div class="glass-card p-6 md:p-8 rounded-2xl border border-white/[0.06] backdrop-blur-xl bg-[rgba(13,17,23,0.35)] text-left">
          <p class="text-white/80 text-base leading-relaxed font-sans">
            {sprintsData.intro.body}
          </p>
        </div>
      </div>
    </div>
  </section>

  {/* Section 1 — Sprint Formats */}
  <section class="relative z-10 py-16 border-t border-white/[0.04]">
    <div class="content-width px-6">
      <div class="max-w-3xl mb-12">
        <h2 class="font-heading font-semibold text-3xl md:text-4xl text-[var(--text-stellar)] mb-4 tracking-tight">
          Three Ways to Sprint
        </h2>
        <p class="text-[var(--text-muted)] text-[var(--text-body)] font-sans">
          Every sprint starts with the same foundation: a focused scope, a dedicated timeline, and clear deliverables. What differs is the level of guidance during implementation.
        </p>
      </div>
      <SprintFormatCard formats={sprintsData.sprintFormats} client:load />
    </div>
  </section>

  {/* Section 2 — Rules of Engagement */}
  <section class="relative z-10 py-16 border-t border-white/[0.04] bg-black/10">
    <div class="content-width px-6">
      <div class="max-w-4xl mx-auto">
        <div class="mb-12">
          <h2 class="font-heading font-semibold text-3xl md:text-4xl text-[var(--text-stellar)] mb-4 tracking-tight">
            Rules of Engagement
          </h2>
          <p class="text-[var(--text-muted)] text-[var(--text-body)] font-sans">
            Sprints work because they're bounded. Clear scope, clear timeline, clear deliverables. Here's how we keep them that way.
          </p>
        </div>
        <RulesOfEngagement rules={sprintsData.rulesOfEngagement} client:load />
      </div>
    </div>
  </section>

  {/* Section 3 — Sprint Domains */}
  <section class="relative z-10 py-16 border-t border-white/[0.04]">
    <div class="content-width px-6">
      <div class="max-w-4xl mx-auto">
        <div class="mb-12">
          <h2 class="font-heading font-semibold text-3xl md:text-4xl text-[var(--text-stellar)] mb-4 tracking-tight">
            {sprintsData.sprintDomains.title}
          </h2>
          <p class="text-[var(--text-muted)] text-[var(--text-body)] font-sans">
            {sprintsData.sprintDomains.subtitle}
          </p>
        </div>
        <SprintDomainTable domainData={sprintsData.sprintDomains} client:load />
      </div>
    </div>
  </section>

  {/* Section 4 — Comparison Table */}
  <section class="relative z-10 py-16 border-t border-white/[0.04] bg-black/5">
    <div class="content-width px-6">
      <div class="max-w-4xl mx-auto">
        <div class="mb-12">
          <h2 class="font-heading font-semibold text-3xl md:text-4xl text-[var(--text-stellar)] mb-4 tracking-tight">
            {sprintsData.sprintVsFull.title}
          </h2>
        </div>
        <SprintVsFullTable comparisonData={sprintsData.sprintVsFull} client:load />
      </div>
    </div>
  </section>

  <PreContact
    title={sprintsData.crossLinks.title}
    subtitle="Establish a secure connection and let's discuss your next sprint."
    buttons={[
      { label: "Book a Discovery Call", href: "#contact?subject=SPRINT_CORE", variant: "primary" },
      { label: "How We Work", href: "/how-we-work", variant: "tertiary" },
      { label: "Explore All Solutions", href: "/solutions", variant: "tertiary" }
    ]}
  />

  <ContactSection />
  <Footer />
</BaseLayout>

---
import BaseLayout from "../../layouts/BaseLayout.astro";
import "../../styles/global.css";
import ContactSection from "../../components/ContactSection.astro";
import PreContact from "../../components/PreContact.astro";
import Footer from "../../components/astro/Footer.astro";
import { AuroraOverlay } from "../../components/react/AuroraOverlay";
import { MobileNav } from "../../components/react/MobileNav";
import { Navbar } from "../../components/react/Navbar";
import { DeliveryTimeline } from "../../components/react/surge/DeliveryTimeline";
import { SurgeStackCard } from "../../components/react/surge/SurgeStackCard";
import { SurgeVsFullTable } from "../../components/react/surge/SurgeVsFullTable";
import { TerminalHero } from "../../components/react/surge/TerminalHero";
import { RainbowButton } from "../../components/ui/rainbow-button";

import surgeData from "../../lib/data/surge-page.json";
---

<BaseLayout title={`${surgeData.hero.title} | Aurorys Labs`}>
  <div class="fixed inset-0 -z-20">
    <div
      class="w-full h-full"
      style="background-image: url('/images/astrophotography/astro-image7.webp'); background-size: cover; background-position: center;"
    ></div>
    <div class="absolute inset-0 bg-gradient-to-b from-[var(--bg-primary)]/40 via-[var(--bg-primary)]/35 to-[var(--bg-primary)]/75"></div>
  </div>

  <AuroraOverlay client:load />
  <Navbar client:load />
  <MobileNav client:load />

  {/* Page Hero */}
  <section class="relative z-10 pt-32 pb-16 md:pt-40 md:pb-24">
    <div class="content-width px-6">
      <div class="max-w-4xl mx-auto text-center space-y-10">
        <div class="space-y-6">
          <h1 class="font-heading font-semibold text-4xl md:text-5xl lg:text-6xl text-gradient-aurora leading-tight tracking-tight">
            {surgeData.hero.title}
          </h1>
          <p class="font-heading font-medium text-lg md:text-xl text-[var(--text-stellar)] max-w-2xl mx-auto">
            {surgeData.hero.subtitle}
          </p>
        </div>

        <TerminalHero sequence={surgeData.hero.terminalSequence} client:load />
      </div>
    </div>
  </section>

  {/* The Problem Section & Prestige Statement */}
  <section class="relative z-10 py-16 border-t border-white/[0.04]">
    <div class="content-width px-6">
      <div class="max-w-4xl mx-auto text-center space-y-12">
        <div class="space-y-4 max-w-2xl mx-auto text-left md:text-center">
          <h2 class="font-heading font-semibold text-3xl md:text-4xl text-[var(--text-stellar)] tracking-tight border-b border-white/[0.06] pb-3">
            {surgeData.problem.title}
          </h2>
          <p class="text-white/80 text-base leading-relaxed font-sans">
            {surgeData.problem.body}
          </p>
        </div>

        <div class="my-8 relative overflow-hidden glass-card p-8 md:p-12 rounded-3xl border border-white/[0.06] bg-[rgba(13,17,23,0.25)]">
          <blockquote class="font-serif italic text-2xl md:text-3xl lg:text-4xl text-[var(--text-stellar)] max-w-3xl mx-auto relative z-10 leading-relaxed">
            "We don't touch your code. <span class="bg-gradient-to-r from-[var(--aurum-gold-subtle-solid)] to-[var(--aurum-gold-light-solid)] bg-clip-text text-transparent animate-rainbow bg-[length:200%]" style="animation-duration: 8s;">You hold the keys. We deploy the capability</span> — and then we leave."
          </blockquote>
        </div>
      </div>
    </div>
  </section>

  {/* Section 1 — Surge Stacks */}
  <section class="relative z-10 py-16 border-t border-white/[0.04]">
    <div class="content-width px-6">
      <div class="max-w-3xl mb-12">
        <h2 class="font-heading font-semibold text-3xl md:text-4xl text-[var(--text-stellar)] mb-4 tracking-tight border-b border-white/[0.06] pb-3">
          Choose Your Configuration
        </h2>
        <p class="text-[var(--text-muted)] text-[var(--text-body)] font-sans">
          Deploy production-ready infrastructure stacks in days. Fully configured, hardened, and documented.
        </p>
      </div>
      <SurgeStackCard stacks={surgeData.stacks} client:load />
    </div>
  </section>

  {/* Section 2 — Delivery Process */}
  <section class="relative z-10 py-16 border-t border-white/[0.04]">
    <div class="content-width px-6">
      <div class="max-w-4xl mx-auto">
        <div class="mb-12">
          <h2 class="font-heading font-semibold text-3xl md:text-4xl text-[var(--text-stellar)] mb-4 tracking-tight border-b border-white/[0.06] pb-3">
            {surgeData.deliveryProcess.title}
          </h2>
          <p class="text-[var(--text-muted)] text-[var(--text-body)] font-sans">
            {surgeData.deliveryProcess.subtitle}
          </p>
        </div>
        <DeliveryTimeline process={surgeData.deliveryProcess} client:load />
      </div>
    </div>
  </section>

  {/* Section 3 — Liability Boundary */}
  <section class="relative z-10 py-16 border-t border-white/[0.04]">
    <div class="content-width px-6">
      <div class="max-w-3xl mx-auto text-center space-y-6">
        <h2 class="font-heading font-semibold text-3xl md:text-4xl text-[var(--text-stellar)] tracking-tight border-b border-white/[0.06] pb-3 text-left md:text-center">
          {surgeData.liabilityBoundary.title}
        </h2>
        <p class="text-white/80 text-base leading-relaxed font-sans text-left md:text-center">
          {surgeData.liabilityBoundary.body}
        </p>

        {/* Liability Boundary H3 Prestige statement */}
        <div class="glass-card p-8 rounded-3xl border border-white/[0.06] bg-[rgba(13,17,23,0.25)] relative overflow-hidden my-8 max-w-2xl mx-auto">
          <blockquote class="font-serif italic text-xl md:text-2xl text-[var(--text-stellar)] relative z-10">
            "We treat you like engineering adults."
          </blockquote>
        </div>

        <p class="text-white/60 text-sm leading-relaxed font-sans text-left md:text-center italic">
          {surgeData.liabilityBoundary.opinionatedNote}
        </p>
      </div>
    </div>
  </section>

  {/* Section 4 — Comparison Table */}
  <section class="relative z-10 py-16 border-t border-white/[0.04]">
    <div class="content-width px-6">
      <div class="max-w-4xl mx-auto">
        <div class="mb-12">
          <h2 class="font-heading font-semibold text-3xl md:text-4xl text-[var(--text-stellar)] mb-4 tracking-tight border-b border-white/[0.06] pb-3">
            {surgeData.surgeVsFull.title}
          </h2>
        </div>
        <SurgeVsFullTable comparisonData={surgeData.surgeVsFull} client:load />
      </div>
    </div>
  </section>

  {/* Compliance Cross Link Banner */}
  <section class="relative z-10 py-16 border-t border-white/[0.04]">
    <div class="content-width px-6">
      <div class="max-w-4xl mx-auto">
        <div class="glass-card p-8 rounded-3xl border border-white/[0.06] flex flex-col md:flex-row items-center justify-between gap-6">
          <div class="space-y-2 text-left">
            <h3 class="font-heading font-semibold text-xl text-[var(--text-stellar)]">
              {surgeData.complianceCrossLink.title}
            </h3>
            <p class="text-white/70 text-sm font-sans max-w-2xl leading-relaxed">
              {surgeData.complianceCrossLink.body}
            </p>
          </div>
          <RainbowButton
            client:load
            variant="glass_alt"
            size="lg"
            className="rounded-xl shrink-0"
            href={surgeData.complianceCrossLink.cta.href}
          >
            {surgeData.complianceCrossLink.cta.label}
          </RainbowButton>
        </div>
      </div>
    </div>
  </section>

  <PreContact
    title={surgeData.crossLinks.title}
    subtitle="Establish a secure connection and let's discuss your deployment."
    buttons={[
      { label: "Book a Discovery Call", href: "#contact?subject=SURGE_BASE", variant: "primary" },
      { label: "How We Work", href: "/how-we-work", variant: "tertiary" },
      { label: "Explore All Solutions", href: "/solutions", variant: "tertiary" }
    ]}
  />

  <ContactSection />
  <Footer />
</BaseLayout>
